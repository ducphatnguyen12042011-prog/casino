datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Bảng User: Lưu trữ tiền tệ Verdict Cash
model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  discordId String   @unique
  balance   Int      @default(5000) 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Bảng Bet: Lưu trữ các vé cược bóng đá
model Bet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  discordId String
  matchId   Int
  amount    Int
  choice    String   // HOME, AWAY, OVER, UNDER
  hcap      Float    // Mức chấp/Tài xỉu tại thời điểm cược
  status    String   @default("PENDING") // WIN, LOSS, DRAW, PENDING
  createdAt DateTime @default(now())
}

// Bảng MatchConfig: Admin thiết lập kèo thủ công
model MatchConfig {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  matchId   Int      @unique
  hcap      Float    @default(0.5)
  total     Float    @default(2.5)
  isLocked  Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

// Bảng Item: Sản phẩm trong Shop
model Item {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String @unique
  price Int    // Giá tính bằng Verdict Cash
}
