datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-api"
}

model User {
  id        String   @id // Discord ID
  balance   BigInt   @default(0)
  profit    BigInt   @default(0)
  lastTrans DateTime @updatedAt
}

model Bet {
  id        Int      @id @default(autoincrement())
  userId    String
  amount    BigInt
  type      String   // 'tai', 'xiu', 'bongda'
  status    String   // 'pending', 'win', 'lose'
}
