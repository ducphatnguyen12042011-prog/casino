// 1. Cấu hình kết nối
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 2. Bảng User: Lưu trữ túi tiền chung và thông tin người chơi
model User {
  discordId String   @id @unique
  balance   Int      @default(5000) // Tặng 5000 xu cho người mới
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 3. Bảng Bet: Lưu trữ lịch sử cược bóng đá (Có Odds và Trạng thái)
model Bet {
  id        Int      @id @default(autoincrement())
  discordId String
  matchId   Int      // ID trận đấu từ Football-Data.org
  amount    Int      // Số tiền đặt cược
  choice    String   // "HOME_TEAM", "AWAY_TEAM", hoặc "DRAW"
  odds      Float    @default(1.9) // Tỷ lệ cược lúc đặt (ví dụ: 1.85, 2.5)
  status    String   @default("PENDING") // PENDING (Đang chờ), WIN (Thắng), LOSS (Thua)
  createdAt DateTime @default(now())
}

// 4. Bảng Item: Danh sách sản phẩm trong Shop do Admin thêm vào
model Item {
  id    Int    @id @default(autoincrement())
  name  String @unique // Tên sản phẩm (ví dụ: TheDoiTen)
  price Int    // Giá tiền để đổi
}
