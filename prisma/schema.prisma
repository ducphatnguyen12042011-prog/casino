// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  // url = env("DATABASE_URL") <-- XÓA HOẶC COMMENT DÒNG NÀY ĐỂ HẾT LỖI P1012
}

model User {
  discordId String   @id @unique
  balance   Int      @default(5000)
  bets      Bet[]
}

model Bet {
  id          Int      @id @default(autoincrement())
  discordId   String
  matchId     String
  choice      String
  amount      Int
  isProcessed Boolean  @default(false)
  user        User     @relation(fields: [discordId], references: [discordId])
}
