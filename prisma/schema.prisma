datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Bảng User: Lưu trữ tiền tệ Verdict Cash
model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  discordId String   @unique
  balance   Int      @default(5000) 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Quan hệ: Một người dùng có thể có nhiều vé cược
  bets      Bet[]
}

// Bảng Bet: Lưu trữ các vé cược bóng đá và casino
model Bet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  amount    Int
  choice    String   // HOME, AWAY, OVER, UNDER, TAI, XIU
  hcap      Float?   // Cho phép null nếu là cược Casino không có chấp
  status    String   @default("PENDING") // WIN, LOSS, DRAW, PENDING
  createdAt DateTime @default(now())

  // Liên kết với bảng User qua discordId
  user      User     @relation(fields: [discordId], references: [discordId])
  discordId String
  
  matchId   Int?     // Cho phép null nếu là cược không theo trận đấu cụ thể
}

// Bảng MatchConfig: Admin thiết lập kèo thủ công
model MatchConfig {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  matchId   Int      @unique
  hcap      Float    @default(0.5)
  total     Float    @default(2.5)
  isLocked  Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

// Bảng Item: Sản phẩm trong Shop
model Item {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  name      String @unique
  price     Int    // Giá tính bằng Verdict Cash
  description String? 
}
