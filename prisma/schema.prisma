// 1. Cấu hình kết nối Database (Dành cho MySQL)
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 2. Generator Client cho Node.js
generator client {
  provider = "prisma-client-js"
}

// --- CÁC MODEL DỮ LIỆU ---

// Bảng User: Lưu trữ thông tin người dùng và số dư
model User {
  id        String   @id @default(uuid()) // MySQL dùng UUID rất tốt
  discordId String   @unique              
  balance   Int      @default(5000) 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Quan hệ: Một User có nhiều đơn cược
  bets      Bet[]
}

// Bảng Transaction: Lưu lịch sử giao dịch (Cho lệnh !lichsu)
model Transaction {
  id        String   @id @default(uuid())
  userId    String   // Discord ID của người sở hữu
  type      String   // NAP, TRU, CHUYEN, NHAN, CUOC, THANG
  amount    Int      
  reason    String?  @db.VarChar(500)
  createdAt DateTime @default(now())

  @@index([userId]) // Giúp truy vấn lịch sử nhanh hơn
}

// Bảng Bet: Lưu trữ các vé cược
model Bet {
  id        String   @id @default(uuid())
  amount    Int
  choice    String   
  hcap      Float?   
  status    String   @default("PENDING") 
  matchId   Int?     
  createdAt DateTime @default(now())

  // Thiết lập quan hệ với User
  user      User     @relation(fields: [discordId], references: [discordId])
  discordId String

  @@index([discordId])
}

// Bảng MatchConfig: Cấu hình kèo cho từng trận đấu
model MatchConfig {
  id        String   @id @default(uuid())
  matchId   Int      @unique
  hcap      Float    @default(0.5)
  total     Float    @default(2.5)
  isLocked  Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

// Bảng Item: Danh sách vật phẩm trong cửa hàng
model Item {
  id          String  @id @default(uuid())
  name        String  @unique
  price       Int     
  description String? @db.VarChar(500)
}
