datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Bảng User: Lưu trữ tiền tệ Verdict Cash
model User {
  discordId String   @id @unique
  balance   Int      @default(5000) // Khởi tạo 5000 Verdict Cash
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Bảng Bet: Lưu trữ các vé cược bóng đá
model Bet {
  id        Int      @id @default(autoincrement())
  discordId String
  matchId   Int
  amount    Int
  choice    String   // HOME, AWAY, OVER, UNDER
  hcap      Float    // Mức chấp/Tài xỉu tại thời điểm cược
  status    String   @default("PENDING") // WIN, LOSS, DRAW, PENDING
  createdAt DateTime @default(now())
}

// Bảng MatchConfig: Admin thiết lập kèo thủ công
model MatchConfig {
  matchId   Int      @id
  hcap      Float    @default(0.5)
  total     Float    @default(2.5)
  isLocked  Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

// Bảng Item: Sản phẩm trong Shop
model Item {
  id    Int    @id @default(autoincrement())
  name  String @unique
  price Int    // Giá tính bằng Verdict Cash
}
