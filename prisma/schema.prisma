datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id      String @id
  balance BigInt @default(5000)
  profit  BigInt @default(0)
}

model Match {
  id        String   @id
  homeTeam  String
  awayTeam  String
  startTime DateTime
  status    String   @default("open") // open, live, closed
}
