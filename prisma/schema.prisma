generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = "mysql://root:root@localhost:3306/mydb" // Dán dòng này vào, kệ nó, Railway sẽ tự thay thế sau
}

model User {
  discordId String   @id @unique
  balance   Int      @default(5000)
  bets      Bet[]
}

model Bet {
  id          Int      @id @default(autoincrement())
  discordId   String
  matchId     String
  choice      String
  amount      Int
  isProcessed Boolean  @default(false)
  user        User     @relation(fields: [discordId], references: [discordId])
}
